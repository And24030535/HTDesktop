<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" style="-fx-background-color: #121212;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.itc.healthtrack.controllers.EmergencyContactsController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox spacing="15.0" prefWidth="380.0" styleClass="panel-secundario" style="-fx-padding: 20;">
        <Label fx:id="lblFormTitle" text="Nuevo Contacto" textFill="WHITE">
            <font><Font name="System Bold" size="18.0"/></font>
        </Label>

        <GridPane hgap="10" vgap="12">
            <Label text="Nombre completo *:" textFill="#cccccc" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="txtName" promptText="Nombre del contacto"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="form-control"/>

            <Label text="Teléfono *:" textFill="#cccccc" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="txtPhone" promptText="Número de teléfono"
                       GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="form-control"/>

            <Label text="Correo:" textFill="#cccccc" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="txtEmail" promptText="correo@ejemplo.com"
                       GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="form-control"/>

            <Label text="Parentesco:" textFill="#cccccc" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="txtRelationship" promptText="Madre, Hermano, Amigo..."
                       GridPane.columnIndex="1" GridPane.rowIndex="3" styleClass="form-control"/>

            <Label text="Contacto principal:" textFill="#cccccc" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <CheckBox fx:id="chkPrimary" text="Sí"
                      GridPane.columnIndex="1" GridPane.rowIndex="4"
                      style="-fx-text-fill: white;"/>
        </GridPane>

        <HBox spacing="10.0" alignment="CENTER">
            <Button fx:id="btnSave" text="Agregar" onAction="#onSaveContact"
                    styleClass="btn, btn-primary" prefWidth="110.0"/>
            <Button text="Eliminar" onAction="#onDeleteContact"
                    styleClass="btn, btn-danger" prefWidth="100.0"/>
            <Button text="Limpiar" onAction="#onClearForm"
                    styleClass="btn, btn-default" prefWidth="100.0"/>
        </HBox>

        <Label fx:id="lblStatus" wrapText="true" textFill="#aaaaaa"/>
    </VBox>

    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
        <Label text="Contactos Registrados" textFill="WHITE">
            <font><Font name="System Bold" size="18.0"/></font>
        </Label>

        <TableView fx:id="tableContacts" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colName"         text="Nombre"       prefWidth="150"/>
                <TableColumn fx:id="colPhone"        text="Teléfono"     prefWidth="110"/>
                <TableColumn fx:id="colEmail"        text="Correo"       prefWidth="170"/>
                <TableColumn fx:id="colRelationship" text="Parentesco"   prefWidth="110"/>
                <TableColumn fx:id="colPrimary"      text="Principal"    prefWidth="80"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</HBox>
