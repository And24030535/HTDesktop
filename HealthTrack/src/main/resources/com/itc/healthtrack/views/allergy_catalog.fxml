<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" style="-fx-background-color: #121212;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.itc.healthtrack.controllers.AllergyCatalogController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox spacing="15.0" prefWidth="360.0" styleClass="panel-secundario" style="-fx-padding: 20;">
        <Label text="Catálogo de Alergias">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>

        <GridPane hgap="10" vgap="12">
            <Label text="Nombre *:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="txtAllergyName" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="form-control"/>

            <Label text="Severidad *:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="comboSeverity" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="form-control"/>
        </GridPane>

        <HBox spacing="10.0" alignment="CENTER">
            <Button text="Guardar" onAction="#onAddAllergy" styleClass="btn, btn-success" prefWidth="100.0"/>
            <Button fx:id="btnToggleActive" text="Desactivar" onAction="#onToggleActive" styleClass="btn, btn-warning" prefWidth="110.0"/>
            <Button text="Limpiar" onAction="#onClearForm" styleClass="btn, btn-default" prefWidth="100.0"/>
        </HBox>

        <Label fx:id="lblAllergyStatus" wrapText="true"/>
    </VBox>

    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
        <Label text="Alergias Registradas">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>

        <TableView fx:id="tableAllergies" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colAllergyName" text="Alergia" prefWidth="220"/>
                <TableColumn fx:id="colAllergySeverity" text="Severidad" prefWidth="200"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</HBox>
